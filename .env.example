# URL del backend (origen, sin /api al final).
# Desarrollo: el proxy de Vite reenvía /api; solo necesitas esto si el backend no está en :3000.
# VITE_API_URL=http://localhost:3000

# Producción (Vercel): obligatorio. Punto a la URL pública del backend.
# VITE_API_URL=https://tu-backend.railway.app
# VITE_API_URL=https://tu-backend.onrender.com
